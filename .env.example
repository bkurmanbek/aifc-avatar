# Avatar system demo environment
# Generated/organized 2026-06-05. Root .env controls backend and local service runners.

# --- Runtime paths ---
# Shared ../data and local runtime binaries.
AIFC_DATA_DIR=/home/admin-aifc/data
DATA_DIR=/home/admin-aifc/data
MODELS_DIR=/home/admin-aifc/models
EMBEDDING_MODEL_PATH=/home/admin-aifc/models/bge-m3
RERANKER_MODEL_PATH=/home/admin-aifc/models/bge-reranker-v2-m3
WS_BACKEND_PYTHON=/home/admin-aifc/miniforge3/envs/synctalk2d/bin/python
SYNCTALK_PYTHON=/home/admin-aifc/miniforge3/envs/synctalk2d/bin/python
SYNCTALK_DIR=/home/admin-aifc/SyncTalk_2D

# --- Backend service ---
# WebSocket backend and local frontend dev server.
WS_BACKEND_HOST=0.0.0.0
WS_BACKEND_PORT=8080
FRONTEND_PORT=5173
MAX_HISTORY_TURNS=6

# --- Provider credentials ---
# Secrets for cloud providers. Keep real values only in .env.
GOOGLE_API_KEY=replace-with-google-api-key
GEMINI_API_KEY=
SONIOX_API_KEY=replace-with-soniox-api-key
ELEVEN_API_KEY=replace-with-elevenlabs-api-key-if-using-elevenlabs

# --- Soniox STT ---
# Realtime STT: endpointing, keepalive, language hints, and abbreviation hints.
# STT_PREVIOUS_TEXT is merged with ../data/abbr.txt-derived context.
SONIOX_STT_WS_URL=wss://stt-rt.soniox.com/transcribe-websocket
SONIOX_STT_MODEL=stt-rt-v4
SONIOX_STT_AUDIO_FORMAT=pcm_s16le
SONIOX_STT_SAMPLE_RATE=16000
SONIOX_STT_LANGUAGE_HINTS=en,ru,kk,zh
SONIOX_STT_LANGUAGE_HINTS_STRICT=true
SONIOX_STT_ENABLE_ENDPOINT_DETECTION=true
SONIOX_STT_MAX_ENDPOINT_DELAY_MS=500
SONIOX_STT_ENDPOINT_WAIT_S=0.25
SONIOX_STT_FINALIZE_TIMEOUT_S=1.0
SONIOX_STT_REALTIME_FINALIZE_TIMEOUT_S=1.0
SONIOX_STT_BATCH_FINALIZE_TIMEOUT_S=3.0
SONIOX_STT_MIN_TOKEN_CONFIDENCE=0.0
SONIOX_STT_PRECONNECT=true
SONIOX_STT_KEEPALIVE_INTERVAL_S=5.0
SONIOX_STT_CONTEXT_MAX_CHARS=10000
SONIOX_STT_CONTEXT_FILE=soniox-context-audio.json
STT_PREVIOUS_TEXT='AIFC, AFSA, AIFCA, AIX, IAC, FinTech Lab, Expat Centre, Astana International Financial Centre, Astana Financial Services Authority, МФЦА, АХҚО'

# --- Gemini LLM ---
# Gemini generation parameters.
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_TEMPERATURE=0.2
GEMINI_MAX_OUTPUT_TOKENS=300

# --- RAG and Qdrant ---
# Local RAG index, chunks, and model settings.
QDRANT_MODE=local
QDRANT_URL=http://localhost:6333
QDRANT_PATH=/home/admin-aifc/data/vector_db
QDRANT_COLLECTION=aifc_chunks
QDRANT_VECTOR_SIZE=1024
RAG_CHUNKS_PATH=/home/admin-aifc/data/chunks/chunks.json
RAG_ANN_TOP_K=20
RAG_FINAL_TOP_K=5
RAG_MIN_ANN_SCORE=0.50
EMBEDDING_BATCH_SIZE=64
INGEST_BATCH_SIZE=64

# --- Answer race and cache ---
# FAQ/cache/local-Gemini-RAG race and cache thresholds.
ANSWER_RACE_ENABLED=true
ANSWER_RACE_TIMEOUT_MS=250
GEMINI_RAG_MAX_WAIT_MS=12000
PARTIAL_WIN_GRACE_MS=350
FAQ_WIN_THRESHOLD=0.90
CACHE_WIN_THRESHOLD=0.90
LOCAL_RAG_HIGH_THRESHOLD=0.65
LOCAL_RAG_PARTIAL_THRESHOLD=0.45
CACHE_HIGH_CONFIDENCE_ONLY=true
EXTERNAL_RAG_ENABLED=false
EXTERNAL_RAG_URL=
EXTERNAL_RAG_API_KEY=
EXTERNAL_RAG_AUTH_HEADER=x-api-key
EXTERNAL_RAG_TIMEOUT_S=8.0
EXTERNAL_RAG_HYBRID=true
EXTERNAL_RAG_WITH_RERANK=true
EXTERNAL_RAG_LIMIT=30
EXTERNAL_RAG_TOP_N=3
EXTERNAL_RAG_HIGH_THRESHOLD=0.25
EXTERNAL_RAG_PARTIAL_THRESHOLD=0.10
AIFC_FALLBACK_EMAIL=info@aifc.kz
LOCAL_RAG_STARTUP_PREWARM=true
LOCAL_RAG_PREWARM_QUERY='What is the AIFC FinTech Lab?'

# --- TTS ---
# Set TTS_PROVIDER=local for OmniVoice; elevenlabs keys are fallback/optional.
TTS_PROVIDER=local
LOCAL_TTS_URL=http://127.0.0.1:8002/tts
ELEVEN_TTS_VOICE_ID=replace-with-elevenlabs-voice-id-if-using-elevenlabs
ELEVEN_TTS_MODEL=eleven_flash_v2_5
ELEVEN_TTS_MODEL_KK=eleven_v3
ELEVEN_TTS_OUTPUT_FORMAT=pcm_22050
ELEVEN_TTS_STABILITY=0.45
ELEVEN_TTS_SIMILARITY_BOOST=0.85
ELEVEN_TTS_STYLE=0.0
ELEVEN_TTS_USE_SPEAKER_BOOST=true
FIRST_TTS_CHARS=12
MIN_TTS_CHARS=24
MAX_TTS_CHARS=80
SHORT_SENTENCE_CHARS=12

# --- SyncTalk avatar video ---
# Change SYNCTALK_AVATAR to switch the loaded SyncTalk avatar checkpoint/dataset.
SYNCTALK_AVATAR=aifc-avatar-5-exp-5-v3
SYNCTALK_HTTP_PORT=8005
SYNCTALK_STREAM_URL=http://127.0.0.1:8005/infer_stream
SYNCTALK_TIMEOUT_S=120.0
SYNCTALK_BATCH_SIZE=32
SYNCTALK_CPU_WORKERS=4
SYNCTALK_GPU_WORKERS=4

# --- Media keepwarm ---
# Keeps local TTS and SyncTalk warm between turns.
MEDIA_KEEPWARM_ENABLED=true
MEDIA_KEEPWARM_INTERVAL_S=45.0
MEDIA_KEEPWARM_TEXT='AIFC is ready.'
MEDIA_KEEPWARM_LANG=en
